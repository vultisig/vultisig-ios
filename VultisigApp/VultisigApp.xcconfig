// VultisigApp.xcconfig
//
// Committed defaults. Holds *no* secrets — declares empty placeholders so the
// Info.plist substitution chain (`$(SWAPKIT_API_KEY)`) compiles even when the
// developer hasn't supplied their own values.
//
// To inject local secrets, create `VultisigApp.local.xcconfig` next to this
// file (it's gitignored) and put your key there:
//
//     SWAPKIT_API_KEY = <uuid-from-partners-dashboard>
//
// The optional `#include?` line below pulls those values in if present.
//
// In CI/production builds, set `SWAPKIT_API_KEY` via the build-time
// environment instead — `SwapKitConfig.apiKey` falls back to
// `ProcessInfo.processInfo.environment` when the Info.plist value is empty.

// Empty placeholder — overridable by `VultisigApp.local.xcconfig`.
SWAPKIT_API_KEY =

#include? "VultisigApp.local.xcconfig"
