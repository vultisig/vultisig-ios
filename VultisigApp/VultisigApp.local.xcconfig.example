// VultisigApp.local.xcconfig.example
//
// Copy this file to `VultisigApp.local.xcconfig` and populate the values
// below for local development. The real file MUST NOT be committed (it's
// gitignored).
//
// `VultisigApp.xcconfig` pulls these values in via `#include?`. The build
// system substitutes them into Info.plist at build time so
// `Bundle.main.object(forInfoDictionaryKey: "SwapKitAPIKey")` returns the
// active key. You can also export `SWAPKIT_API_KEY` in your shell and rely
// on the process-environment fallback in `SwapKitConfig.swift`.

// SwapKit partner API key. Empty in this example so the file can ship
// committed; populate the value in your local copy.
SWAPKIT_API_KEY =
